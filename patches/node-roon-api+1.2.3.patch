+                        // When a core is reachable over multiple interfaces
+                        // (e.g. LAN and a VPN like ZeroTier), discovery is a
+                        // race and the winning path varies per reconnect. Roon
+                        // scopes the extension identity by host address, so a
+                        // flapping path silently breaks the zone's volume and
+                        // source control bindings. ROON_CORE_IP pins discovery
+                        // to one core address to keep the identity stable.
+                        if (typeof(process) !== "undefined" && process.env && process.env.ROON_CORE_IP && msg.from.ip !== process.env.ROON_CORE_IP) {
+                            this.logger.log("Ignoring discovery response from " + msg.from.ip + " (ROON_CORE_IP=" + process.env.ROON_CORE_IP + ")");
+                            return;
+                        }
                         if (this._sood_conns[msg.props.unique_id]) {
                             return;
                         }
